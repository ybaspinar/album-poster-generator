{
  "name": "album-poster-generator",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vite build",
    "preview": "vp preview",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "check": "vp check",
    "lint": "vp lint -c .oxlintrc.json",
    "fmt": "vp fmt",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:fix": "fallow fix --dry-run",
    "fallow:fix:write": "fallow fix --yes",
    "fallow:audit": "fallow audit",
    "pre-commit": "pnpm fallow:dead-code && pnpm lint && pnpm exec vue-tsc --noEmit --project tsconfig.app.json"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm pre-commit"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "extract-colors": "^4.2.1",
    "html-to-image": "latest",
    "pinia": "^3.0.4",
    "posthog-js": "^1.376.5",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vue": "latest",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "latest",
    "@vitejs/plugin-vue": "latest",
    "@vue/test-utils": "latest",
    "fallow": "latest",
    "jsdom": "latest",
    "simple-git-hooks": "^2.13.1",
    "typescript": "latest",
    "vite": "latest",
    "vite-plus": "latest",
    "vitest": "latest",
    "vue-tsc": "latest"
  },
  "packageManager": "pnpm@10.12.1"
}
